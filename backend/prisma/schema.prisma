generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Salon {
  id   String @id @default(uuid())
  name String

  branches Branch[]

  addressLine1 String?
  addressLine2 String?

  city       String?
  state      String?
  country    String?
  postalCode String?

  sales Sale[]

  phone String?
  email String?

  mainServices MainService[]
  services     Service[]

  appointments Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]
  payments Payment[]

  users                User[]
  staff                Staff[]
  customers            Customer[]
  customerTransactions CustomerTransaction[]
  supportTickets       SupportTicket[]
}

model User {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  phone_number String? @unique
  passwordHash String
  role         Role    @default(STAFF)
  salonId      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  appointmentStatusChanges AppointmentStatusHistory[] @relation("AppointmentStatusChangedBy")
  createdAppointments      Appointment[]              @relation("AppointmentCreatedBy")

  salesCreated Sale[] @relation("SaleCreatedBy")
  salesEdited  Sale[] @relation("SaleEditedBy")
  salesDeleted Sale[] @relation("SaleDeletedBy")

  salePaymentsReceived SalePayment[] @relation("SalePaymentReceivedBy")
  staffProfile         Staff?
  salon                Salon?        @relation(fields: [salonId], references: [id])

  reportedSupportTickets     SupportTicket[]              @relation("SupportTicketReporter")
  assignedSupportTickets     SupportTicket[]              @relation("SupportTicketAssignedTo")
  supportTicketMessages      SupportTicketMessage[]       @relation("SupportTicketMessageSender")
  supportTicketStatusChanges SupportTicketStatusHistory[] @relation("SupportTicketStatusChangedBy")
}

model Customer {
  id           String @id @default(uuid())
  customerCode String

  name  String
  phone String?
  email String?
  gst   String?

  customNotes String?

  dob             DateTime?
  anniversaryDate DateTime?

  status CustomerStatus @default(REGULAR)

  outstandingAmount Decimal @default(0)
  walletBalance     Decimal @default(0)

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  transactions CustomerTransaction[]
  appointments Appointment[]

  sales Sale[]

  invoices Invoice[]
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([salonId, customerCode])
  @@unique([salonId, phone])
  @@unique([salonId, email])
}

enum CustomerStatus {
  REGULAR
  PREMIUM
  IRREGULAR
}

model CustomerTransaction {
  id String @id @default(uuid())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id])

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  paymentId String?
  payment   Payment? @relation(fields: [paymentId], references: [id])

  billNo    String?
  narration String

  type CustomerTransactionType @default(ADJUSTMENT)

  debit  Decimal @default(0) @db.Decimal(10, 2)
  credit Decimal @default(0) @db.Decimal(10, 2)

  balanceAfter Decimal @default(0) @db.Decimal(10, 2)

  status TransactionStatus @default(COMPLETE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([salonId])
  @@index([invoiceId])
  @@index([paymentId])
  @@index([type])
  @@index([createdAt])
}

enum TransactionStatus {
  PENDING
  COMPLETE
  FAILED
}

model Branch {
  id   String @id @default(uuid())
  name String

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id])

  addressLine1 String?
  city         String?
  state        String?
  postalCode   String?
  phone        String?

  staff     Staff[]
  customers Customer[]
  services  Service[]

  users User[]

  sales Sale[]

  invoices Invoice[]
  payments Payment[]

  appointments Appointment[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  supportTickets SupportTicket[]

  @@unique([salonId, name])
}

model Staff {
  id          String   @id @default(uuid())
  staffCode   String?
  name        String
  email       String
  phone       String?
  jobRole     String
  workingFrom String
  workingTo   String
  weekOff     String
  joiningDate DateTime @default(now())
  status      Boolean  @default(true)

  salonId String
  userId  String? @unique

  reportingManagerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reportingManager Staff?  @relation("StaffReportingManager", fields: [reportingManagerId], references: [id])
  reportees        Staff[] @relation("StaffReportingManager")

  sales Sale[]

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  salon Salon @relation(fields: [salonId], references: [id])
  user  User? @relation(fields: [userId], references: [id])

  appointments Appointment[]

  @@unique([salonId, email])
  @@unique([salonId, staffCode])
}

enum Role {
  SUPER_ADMIN
  SALON_ADMIN
  BRANCH_MANAGER
  RECEPTIONIST
  STAFF
}

model MainService {
  id     String  @id @default(uuid())
  name   String
  status Boolean @default(true)

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id])

  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([salonId, name])
  @@index([salonId])
  @@index([status])
}

model Service {
  id          String  @id @default(uuid())
  name        String
  description String?

  price         Decimal      @db.Decimal(10, 2)
  durationValue Int?
  durationUnit  DurationUnit @default(MINUTES)

  status Boolean @default(true)

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  mainServiceId String
  mainService   MainService @relation(fields: [mainServiceId], references: [id])

  appointmentServices AppointmentService[]

  saleItems SaleItem[]

  invoiceItems InvoiceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([salonId, mainServiceId, name])
  @@index([salonId])
  @@index([branchId])
  @@index([mainServiceId])
  @@index([status])
}

enum DurationUnit {
  MINUTES
  HOURS
}

model Appointment {
  id              String @id @default(uuid())
  appointmentCode String

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id])

  createdById String?
  createdBy   User?   @relation("AppointmentCreatedBy", fields: [createdById], references: [id])

  startTime DateTime
  endTime   DateTime

  totalDurationMinutes Int     @default(0)
  estimatedAmount      Decimal @default(0) @db.Decimal(10, 2)

  status AppointmentStatus @default(SCHEDULED)

  bookingNote  String?
  internalNote String?

  services AppointmentService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoice       Invoice?
  statusHistory AppointmentStatusHistory[]

  @@unique([salonId, appointmentCode])
  @@index([salonId])
  @@index([branchId])
  @@index([customerId])
  @@index([staffId])
  @@index([createdById])
  @@index([status])
  @@index([startTime])
  @@index([salonId, startTime])
  @@index([staffId, startTime, endTime])
}

model AppointmentStatusHistory {
  id String @id @default(uuid())

  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  oldStatus AppointmentStatus?
  newStatus AppointmentStatus

  note String?

  changedById String?
  changedBy   User?   @relation("AppointmentStatusChangedBy", fields: [changedById], references: [id])

  createdAt DateTime @default(now())

  @@index([appointmentId])
  @@index([changedById])
  @@index([newStatus])
  @@index([createdAt])
}

model AppointmentService {
  id String @id @default(uuid())

  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  serviceName String
  price       Decimal @db.Decimal(10, 2)

  durationValue Int?
  durationUnit  DurationUnit?

  createdAt DateTime @default(now())

  @@index([appointmentId])
  @@index([serviceId])
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum SaleStatus {
  ACTIVE
  DELETED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentStatus {
  PAID
  PARTIALLY_PAID
  UNPAID
  REFUNDED
}

enum PaymentMethod {
  CASH
  UPI
  GPAY
  PAYTM
  PHONEPE
  CARD
  BANK_TRANSFER
  CHEQUE
  OTHER
}

enum SaleItemType {
  SERVICE
  PRODUCT
  CUSTOM
}

model Sale {
  id String @id @default(uuid())

  saleCode String @unique

  salonId  String
  branchId String?

  customerId    String?
  customerName  String
  customerPhone String?
  customerEmail String?

  staffId   String?
  staffName String?

  invoiceNumber String?  @unique
  invoiceDate   DateTime @default(now())

  saleDate DateTime @default(now())

  subtotalAmount Decimal @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  taxPercent     Decimal @default(0) @db.Decimal(5, 2)
  taxAmount      Decimal @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal @db.Decimal(10, 2)

  paidAmount Decimal @default(0) @db.Decimal(10, 2)
  dueAmount  Decimal @default(0) @db.Decimal(10, 2)

  paymentStatus PaymentStatus  @default(UNPAID)
  paymentMethod PaymentMethod?
  paymentNote   String?

  status SaleStatus @default(ACTIVE)

  createdById String?
  editedById  String?

  deletedAt    DateTime?
  deletedById  String?
  deleteReason String?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salon  Salon   @relation(fields: [salonId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id])

  customer Customer? @relation(fields: [customerId], references: [id])
  staff    Staff?    @relation(fields: [staffId], references: [id])

  createdBy User? @relation("SaleCreatedBy", fields: [createdById], references: [id])
  editedBy  User? @relation("SaleEditedBy", fields: [editedById], references: [id])
  deletedBy User? @relation("SaleDeletedBy", fields: [deletedById], references: [id])

  items    SaleItem[]
  payments SalePayment[]

  @@index([salonId])
  @@index([branchId])
  @@index([customerId])
  @@index([staffId])
  @@index([saleDate])
  @@index([status])
  @@index([paymentStatus])
}

model SaleItem {
  id String @id @default(uuid())

  saleId String

  serviceId String?

  itemType SaleItemType @default(SERVICE)

  itemName String

  quantity Int @default(1)

  unitPrice      Decimal @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  taxPercent     Decimal @default(0) @db.Decimal(5, 2)
  taxAmount      Decimal @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  service Service? @relation(fields: [serviceId], references: [id])

  @@index([saleId])
  @@index([serviceId])
  @@index([itemType])
}

model SalePayment {
  id String @id @default(uuid())

  saleId String

  amount Decimal @db.Decimal(10, 2)

  method PaymentMethod

  transactionId String?
  referenceNo   String?

  paidAt DateTime @default(now())

  receivedById String?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  receivedBy User? @relation("SalePaymentReceivedBy", fields: [receivedById], references: [id])

  @@index([saleId])
  @@index([method])
  @@index([paidAt])
  @@index([receivedById])
}

model Invoice {
  id          String @id @default(uuid())
  invoiceCode String

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  invoiceType InvoiceType @default(BILL_OF_SUPPLY)

  invoiceDate DateTime @default(now())

  salonName    String
  salonPhone   String?
  salonEmail   String?
  salonAddress String?
  salonGst     String?

  customerName    String
  customerPhone   String?
  customerEmail   String?
  customerAddress String?
  customerGst     String?

  subtotalAmount      Decimal @default(0) @db.Decimal(10, 2)
  discountAmount      Decimal @default(0) @db.Decimal(10, 2)
  processingFeeAmount Decimal @default(0) @db.Decimal(10, 2)
  taxAmount           Decimal @default(0) @db.Decimal(10, 2)
  totalAmount         Decimal @default(0) @db.Decimal(10, 2)

  paidAmount    Decimal @default(0) @db.Decimal(10, 2)
  balanceAmount Decimal @default(0) @db.Decimal(10, 2)

  status        InvoiceStatus @default(ISSUED)
  paymentStatus PaymentStatus @default(UNPAID)

  billingNote String?
  footerNote  String?

  items    InvoiceItem[]
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerTransactions CustomerTransaction[]

  @@unique([salonId, invoiceCode])
  @@index([salonId])
  @@index([branchId])
  @@index([customerId])
  @@index([appointmentId])
  @@index([invoiceDate])
  @@index([status])
  @@index([paymentStatus])
}

model InvoiceItem {
  id String @id @default(uuid())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  itemCode    String?
  description String
  serviceName String

  quantity Int @default(1)

  unitPrice Decimal @db.Decimal(10, 2)

  discountAmount Decimal @default(0) @db.Decimal(10, 2)

  taxPercent Decimal @default(0) @db.Decimal(5, 2)
  taxAmount  Decimal @default(0) @db.Decimal(10, 2)

  lineTotal Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([serviceId])
}

model Payment {
  id String @id @default(uuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  amount Decimal @db.Decimal(10, 2)

  method PaymentMethod

  referenceNo String?
  note        String?

  paidAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerTransactions CustomerTransaction[]

  @@index([salonId])
  @@index([branchId])
  @@index([customerId])
  @@index([invoiceId])
  @@index([method])
  @@index([paidAt])
}

enum InvoiceType {
  GST_INVOICE
  BILL_OF_SUPPLY
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  CANCELLED
}

enum CustomerTransactionType {
  INVOICE
  PAYMENT
  WALLET_ADD
  WALLET_USED
  REFUND
  ADJUSTMENT
}

model SupportTicket {
  id         String @id @default(uuid())
  ticketCode String

  salonId String?
  salon   Salon?  @relation(fields: [salonId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  reporterId String?
  reporter   User?   @relation("SupportTicketReporter", fields: [reporterId], references: [id])

  reporterName  String?
  reporterEmail String
  reporterPhone String?

  title       String
  description String

  category SupportTicketCategory @default(OTHER)
  priority SupportTicketPriority @default(MEDIUM)
  status   SupportTicketStatus   @default(OPEN)

  source SupportTicketSource @default(DASHBOARD)

  pageUrl      String?
  browserInfo  String?
  errorMessage String?

  assignedToId String?
  assignedTo   User?   @relation("SupportTicketAssignedTo", fields: [assignedToId], references: [id])

  resolutionNotes String?

  messages      SupportTicketMessage[]
  statusHistory SupportTicketStatusHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ticketCode])
  @@index([salonId])
  @@index([branchId])
  @@index([reporterId])
  @@index([reporterEmail])
  @@index([assignedToId])
  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([createdAt])
}

model SupportTicketMessage {
  id String @id @default(uuid())

  ticketId String
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  senderId String?
  sender   User?   @relation("SupportTicketMessageSender", fields: [senderId], references: [id])

  senderEmail String?
  message     String

  isInternalNote Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([senderId])
}

model SupportTicketStatusHistory {
  id String @id @default(uuid())

  ticketId String
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  oldStatus SupportTicketStatus?
  newStatus SupportTicketStatus

  changedById String?
  changedBy   User?   @relation("SupportTicketStatusChangedBy", fields: [changedById], references: [id])

  note String?

  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([changedById])
  @@index([newStatus])
  @@index([createdAt])
}

enum SupportTicketCategory {
  LOGIN_ISSUE
  CUSTOMER_MODULE
  APPOINTMENT_MODULE
  STAFF_MODULE
  SERVICE_MODULE
  BILLING_INVOICE
  PAYMENT_MODULE
  REPORTS
  PERFORMANCE
  BUG
  OTHER
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_FOR_USER
  RESOLVED
  CLOSED
  REJECTED
}

enum SupportTicketSource {
  LOGIN_PAGE
  DASHBOARD
}
